{
  "name": "template-vanilla-vuejs",
  "private": true,
  "author": "richard moalic",
  "version": "1.1.0",
  "type": "module",
  "license": "MIT",
  "keywords": [],
  "description": "",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,vue,ts,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "pnpm": {
    "overrides": {
      "glob": "^10.5.0",
      "esbuild": "^0.25.0",
      "vite": ">=6.4.2"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:staging": "vite --mode staging",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "serve": "vite preview --host",
    "prepare": "husky",
    "cm": "czg",
    "cm:check": "commitlint --edit",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx,vue,cjs,mjs}\"",
    "lint:p": "prettier --w",
    "lint:check": "eslint \"src/**/*.{ts,tsx,js,jsx,vue,cjs,mjs}\" --max-warnings=0",
    "lint:js:fix": "eslint \"src/**/*.{ts,tsx,js,jsx,vue,cjs,mjs}\" --fix",
    "lint:css": "stylelint \"src/**/*.{vue,css,scss}\" --max-warnings=0",
    "lint:style": "stylelint \"src/**/*.{css,vue}\" --fix",
    "lint:fix": "pnpm lint:js:fix && pnpm lint:style",
    "lint:sh": "shellcheck .github/scripts/*.sh",
    "lint:report": "eslint \"src/**/*.{ts,tsx,js,jsx}\" -f html -o eslint-report.html",
    "format:check": "prettier --write .",
    "lint:report:json": "eslint \"src/**/*.{ts,tsx,js,jsx}\" -f json -o eslint-report.json",
    "docs:api": "typedoc",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "docs:generate": "pnpm docs:api && pnpm docs:build",
    "test": "rm -rf coverage && vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "rm -rf coverage && vitest run --coverage --passWithNoTests",
    "test:unit": "vitest run",
    "test:related": "vitest related --run --no-coverage",
    "test:component": "vitest run -t \"component\"",
    "test:e2e": "playwright test --reporter=html || true",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "release:dry": "semantic-release --dry-run",
    "release": "semantic-release"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cz-git": "^1.12.0",
    "czg": "^1.13.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vite": "^8.0.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  }
}
