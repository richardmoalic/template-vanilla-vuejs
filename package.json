{
  "name": "template-vanilla-vuejs",
  "private": true,
  "author": "richard moalic",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "keywords": [],
  "description": "",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ],
    "*.{css,scss,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:staging": "vite --mode staging",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "serve": "vite preview --host",
    "prepare": "husky",
    "commit": "cz",
    "commit:check": "commitlint --edit",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx,vue,cjs,mjs}\"",
    "lint:check": "eslint \"src/**/*.{ts,tsx,js,jsx,vue,cjs,mjs}\" --max-warnings=0",
    "lint:js:fix": "eslint \"src/**/*.{ts,tsx,js,jsx,vue,cjs,mjs}\" --fix",
    "lint:css": "stylelint \"src/**/*.{vue,css,scss}\" --max-warnings=0",
    "lint:style": "stylelint \"src/**/*.{css,vue}\" --fix",
    "lint:fix": "pnpm lint:js:fix && pnpm lint:style",
    "lint:report": "eslint \"src/**/*.{ts,tsx,js,jsx}\" -f html -o eslint-report.html",
    "lint:report:json": "eslint \"src/**/*.{ts,tsx,js,jsx}\" -f json -o eslint-report.json",
    "docs": "jsdoc -c jsdoc.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run -t \"unit\"",
    "test:component": "vitest run -t \"component\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "release": "semantic-release --dry-run",
    "release:ci": "semantic-release"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "cz-git": "^1.12.0",
    "docdash": "^2.0.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "stylint": "^2.0.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
