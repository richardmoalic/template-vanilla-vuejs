#!/bin/sh

# ==========================================================
# HOOK TYPE: PRE-PUSH (Remote Gatekeeper)
# TOOL: Husky
# VERSION: v9.1.7 (Stable)
# PRE-PUSH CONFIGURATION
# DOCUMENTATION: https://typicode.github.io/husky
# PURPOSE:
#   Final local validation to ensure that pushed code won't break the CI/CD pipeline.
# USE CASES:
#   1. Validation: Run full build (vite build) to catch type errors.
#   2. Compliance: Strict linting (max-warnings=0) to prevent "style-drift".
#   3. Verification: Run related unit tests (vitest).
# EXECUTION:
#   - MODE: Blocking (Prevents 'git push' to remote)
# SCOPE:
#   - Current branch vs Remote Tracking branch.
# CONTEXT:
#   - Stack: Vite + pnpm + Vue/React
# SECURITY NOTES:
#   - Last local check. Ensures no compliance code or broken builds reach
#     the shared repository.
# DEPENDENCIES:
#   - commitlint.config.mjs → Defines commit message rules
#   - trufflehog.yml → secrets scanning configuration
#   - package.json#scripts.lint:css → Stylint
#   - package.json#scripts.lint:check → Eslint
#   - package.json#scripts.test:related → Vitest
#   - package.json#scripts.build → Vite build
# MAINTENANCE:
#   - Update version quarterly
#   - Review update for: eslint/stylelint/prettier/vitest/vite/trufflehog
#   - Owner: @gituser
# ==========================================================

echo "Running pre-push checks..."

trufflehog git file://"$PWD" --since-commit HEAD~1 --only-verified --no-update --fail

echo "--- Linting css ---"
pnpm lint:css || exit 1

echo "--- Linting js ---"
pnpm lint:check || exit 1

echo "--- Running tests ---"
if [ -z "$(git ls-files 'src/**/*.{test,spec}.{js,ts,vue}')" ]; then
  echo "⚠️ No tests found in repo → skipping"
else
  pnpm test:related || pnpm test:run || exit 1
  
fi

CHANGED_SRC=$(git diff --name-only HEAD~1 | grep '^src/' || true)
CHANGED_TESTS=$(git diff --name-only HEAD~1 | grep -E '\.(test|spec)\.' || true)

if [ -n "$CHANGED_SRC" ] && [ -z "$CHANGED_TESTS" ]; then
  echo "❌ You changed source files but no tests were updated/added"
  exit 1
fi

echo "--- Validating Build Consistency ---"
pnpm build || exit 1
